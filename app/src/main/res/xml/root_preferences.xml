<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Configurações do mapa">

        <SeekBarPreference
            app:defaultValue="14"
            app:key="pref_map_default_zoom"
            android:max="20"
            app:min="1"
            app:showSeekBarValue="true"
            app:title="@string/default_zoom_title"
            app:updatesContinuously="true" />

        <ListPreference
            app:defaultValue="roadmap"
            app:entries="@array/map_type_entries"
            app:entryValues="@array/map_type_values"
            app:key="pref_map_type"
            app:title="@string/map_type_title"
            app:useSimpleSummaryProvider="true" />


    </PreferenceCategory>

</PreferenceScreen>