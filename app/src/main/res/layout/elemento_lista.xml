<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/elemento_lista"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <Space
        android:id="@+id/spaceTopo"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivFotoElementoLista"
        android:layout_width="70dp"
        android:layout_height="78dp"
        android:layout_marginStart="12dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spaceTopo" />


    <TextView
        android:id="@+id/tvNomeElementoLista"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Nome"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@+id/ivFotoElementoLista"
        app:layout_constraintEnd_toStartOf="@+id/btEditarElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/spaceTopo" />

    <TextView
        android:id="@+id/tvDescricaoElementoLista"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Descrição"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@+id/tvNomeElementoLista"
        app:layout_constraintEnd_toStartOf="@+id/btEditarElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/tvNomeElementoLista" />

    <TextView
        android:id="@+id/tvEnderecoElementoLista"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Endereço"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@+id/tvNomeElementoLista"
        app:layout_constraintEnd_toStartOf="@+id/btEditarElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/tvDescricaoElementoLista" />


    <ImageButton
        android:id="@+id/btEditarElementoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="35dp"

        android:background="@null"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/tvEnderecoElementoLista"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvNomeElementoLista"
        app:srcCompat="@android:drawable/ic_menu_edit" />

    <Space
        android:id="@+id/space"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvEnderecoElementoLista"
        tools:layout_editor_absoluteX="140dp" />

</androidx.constraintlayout.widget.ConstraintLayout>